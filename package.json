{
  "name": "skonester-ck3-mod-installer",
  "version": "1.19.0",
  "description": "Universal CK3 Mod Installer - mod1, mod2, mod3 auto-slotting",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "dist:win": "electron-builder --win portable",
    "dist:mac": "electron-builder --mac dmg",
    "dist:linux": "electron-builder --linux AppImage",
    "dist:all": "electron-builder -mwl",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "yauzl-promise": "^4.0.0"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.skonester.ck3modinstaller",
    "productName": "CK3 Mod Installer",
    "executableName": "CK3-Mod-Installer",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "portable": {
      "unpackDirName": false
    },
    "mac": {
      "target": ["dmg"],
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "compression": "maximum"
  }
}